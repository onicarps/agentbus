+def _resolve_go_serve_binary() -> Path:
+    """Locate agentbus-go-serve for --engine go (Strangler spike)."""
+    env = os.environ.get("AGENTBUS_GO_SERVE")
+    if env:
+        p = Path(env).expanduser()
